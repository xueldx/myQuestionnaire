# Root local environment template
# Copy this file to `.env` before local development or deployment.

# Docker image publishing
ALIYUN_USERNAME=your_registry_username
ALIYUN_PASSWORD=your_registry_password
ALIYUN_REGISTRY_URL=registry.example.com/your-namespace
FRONTEND_IMAGE_NAME=questionnaire-frontend
CLIENT_IMAGE_NAME=questionnaire-client
BACKEND_IMAGE_NAME=questionnaire-backend
FRONTEND_DOCKERFILE_PATH=./packages/questionnaire-fe/Dockerfile
CLIENT_DOCKERFILE_PATH=./packages/questionnaire-client/Dockerfile
BACKEND_DOCKERFILE_PATH=./packages/questionnaire-be/Dockerfile

# Local / Docker compose ports
DOCKER_FRONTEND_PORT=8877
DOCKER_CLIENT_PORT=8878
DOCKER_BACKEND_PORT=8879
MYSQL_HOST_PORT=33306
MYSQL_CONTAINER_PORT=3307
MONGO_HOST_PORT=27017
REDIS_HOST_PORT=6379

# Shared app configuration
TZ=Asia/Shanghai
APP_DOMAIN=http://localhost
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=1d
INTERNAL_API_SECRET=change_me_internal_secret
BACKEND_API_BASE_URL=http://localhost:8879/api

# MySQL
MYSQL_HOST=localhost
MYSQL_USERNAME=root
MYSQL_PASSWORD=change_me_mysql_password
MYSQL_DATABASE=questionnaire_db

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_USERNAME=admin
MONGO_PASSWORD=change_me_mongo_password
MONGO_DB_NAME=questionnaire_mongo_db
MONGO_AUTH_SOURCE=admin

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Mailer
MAILER_USER=your_mail@example.com
MAILER_PASS=your_mail_password
MAILER_HOST=smtp.example.com
MAILER_PORT=465

# AI model runtime config
MODELSCOPE_QWEN3_MODEL=your_model_id_here
MODELSCOPE_QWEN3_API_KEY=your_modelscope_qwen3_api_key
MODELSCOPE_QWEN3_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_GLM5_MODEL=your_model_id_here
MODELSCOPE_GLM5_API_KEY=your_modelscope_glm5_api_key
MODELSCOPE_GLM5_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_KIMIK2_MODEL=your_model_id_here
MODELSCOPE_KIMIK2_API_KEY=your_modelscope_kimik2_api_key
MODELSCOPE_KIMIK2_BASE_URL=https://api-inference.modelscope.cn/v1
