# Copy this file to `.env.local` before starting the questionnaire client locally.

CLIENT_PORT=8878
BACKEND_API_BASE_URL=http://localhost:8879/api
INTERNAL_API_SECRET=change_me_internal_secret

MONGO_HOST=localhost
MONGO_PORT=27017
